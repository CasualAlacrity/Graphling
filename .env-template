# LangSmith (tracing/observability - highly recommended while learning)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="Graphling"

# LLM provider(s) - only include the ones you actually use
# (ollama / openai / anthropic)
LLM_PROVIDER=openai

# Ollama
OLLAMA_CHAT_MODEL=gemma4
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Star Citizen API Keys
UEXCORP_API_KEY=
UEXCORP_BEARER_TOKEN=

# Push-to-talk voice
# PTT_MODE=text falls back to typed input instead of the real hotkey/mic —
# useful on macOS until the running process (e.g. PyCharm) has Accessibility
# permission granted under System Settings > Privacy & Security > Accessibility.
# Not needed on Windows — hotkey mode should work out of the box there.
PTT_MODE=hotkey
PTT_HOTKEY=shift_r

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Trade route tracker (Postgres, via docker-compose — these match
# docker-compose.yml's defaults, only change them if you also change it)
DATABASE_URL=postgresql://graphling:graphling@localhost:5433/graphling

# Overlay: on by default, starts the voice loop (LangGraph/LLM/TTS) alongside the
# trade panel. Set to 0 to run the overlay standalone without that stack configured.
UPLINK_VOICE=1
